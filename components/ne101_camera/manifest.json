{
  "id": "ne101_camera",
  "name": { "en": "NE101 Camera Panel", "zh": "NE101 感知摄像头面板" },
  "description": {
    "en": "CamThink NE101 sensing camera — displays latest capture, battery status, and trigger controls",
    "zh": "CamThink NE101 感知摄像头 — 显示最新抓拍、电量状态和触发控制"
  },
  "icon": "Camera",
  "category": "device",
  "version": "2.1.0",
  "author": "CamThink Team",
  "size_constraints": { "min_w": 2, "min_h": 2, "default_w": 3, "default_h": 3, "max_w": 6, "max_h": 6 },
  "has_data_source": false,
  "has_device_binding": true,
  "device_type_filter": ["ne101_camera"],
  "has_display_config": true,
  "has_actions": false,
  "config_schema": {
    "type": "object",
    "properties": {
      "showMetrics": {
        "type": "boolean",
        "default": true,
        "title": "Show Metrics Panel"
      },
      "showCommands": {
        "type": "boolean",
        "default": true,
        "title": "Show Command Buttons"
      },
      "location": {
        "type": "string",
        "default": "",
        "title": "Location Title"
      },
      "processing": {
        "type": "object",
        "title": "Processing Pipeline",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": false,
            "title": "Enable Processing"
          },
          "extensionId": {
            "type": "string",
            "default": "",
            "title": "Extension ID",
            "description": "ID of the installed extension (e.g. locate-anything-v2)"
          },
          "template": {
            "type": "string",
            "default": "object_detection",
            "enum": ["object_detection", "object_detection_roi", "grounding", "text_detection"],
            "title": "Processing Template",
            "description": "Built-in template that determines the transform pipeline"
          },
          "categories": {
            "type": "string",
            "default": "person,car",
            "title": "Detection Categories",
            "description": "Comma-separated categories for detect mode"
          },
          "phrase": {
            "type": "string",
            "default": "",
            "title": "Search Phrase",
            "description": "Description for grounding / text detection modes"
          },
          "roi": {
            "type": "object",
            "title": "Region of Interest",
            "description": "Normalized [0-1] rectangle for ROI-based counting",
            "properties": {
              "x": { "type": "number", "default": 0.1, "minimum": 0, "maximum": 1 },
              "y": { "type": "number", "default": 0.1, "minimum": 0, "maximum": 1 },
              "w": { "type": "number", "default": 0.8, "minimum": 0, "maximum": 1 },
              "h": { "type": "number", "default": 0.8, "minimum": 0, "maximum": 1 }
            }
          },
          "classFilter": {
            "type": "string",
            "default": "",
            "title": "Class Filter",
            "description": "Comma-separated class names to include. Empty = all classes."
          }
        }
      }
    }
  },
  "default_config": {
    "showMetrics": true,
    "showCommands": true,
    "location": "",
    "processing": {
      "enabled": false,
      "extensionId": "",
      "template": "object_detection",
      "categories": "person,car",
      "phrase": "",
      "roi": { "x": 0.1, "y": 0.1, "w": 0.8, "h": 0.8 },
      "classFilter": ""
    }
  },
  "global_name": "NE101CameraPanel",
  "export_name": "NE101CameraPanel"
}
